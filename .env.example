# Copy this file to .env for local testing (do NOT commit .env).
# On Render.com, set these as Environment Variables in the service dashboard.

# Required: Supabase Postgres connection string (from Supabase → Project Settings → Database → Connection string → URI / "Transaction pooler")
# Example: postgresql://postgres.xxxxx:YOUR-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Optional: Pre-configure a Gemini API key for all users (instead of asking parent to paste it in Settings)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override default Gemini model
GEMINI_MODEL=gemini-2.5-flash
